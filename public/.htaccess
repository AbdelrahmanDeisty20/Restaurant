DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. استثناء الملفات الحقيقية (صور، CSS، JS)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. توجيه إجباري: أي رابط فيه كلمة /lang/ يروح للداشبورد فوراً
    # لأنك قلت إن الموقع ملوش روت للترجمة، يبقى السكة دي ملك للباك إند بس
    RewriteCond %{REQUEST_URI} ^/lang/ [NC]
    RewriteRule ^ index.php [L]

    # 3. توجيه الأدمن والـ API والـ Livewire
    RewriteCond %{REQUEST_URI} ^/(admin|api|livewire|filament) [NC]
    RewriteRule ^ index.php [L]

    # 4. أي حاجة تانية للموقع (React)
    RewriteRule ^ index.html [L]
</IfModule>