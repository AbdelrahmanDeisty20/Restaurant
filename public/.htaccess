<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. لو المسار هو ملف موجود فعلاً (صورة، CSS، JS) افتحه عادي
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. استثناء مسارات الباك إند (الأدمين والـ API) عشان ميروحوش للريأكت
    RewriteCond %{REQUEST_URI} ^/(admin|api|storage|login|logout|livewire|filament) [NC]
    RewriteRule ^ index.php [L]

    # 3. الحل السحري: أي مسار تاني (زي /menu) ابعته لـ index.html
    # السطر ده هو اللي هيخلي الريفريش يشتغل
    RewriteRule ^ index.html [L]
</IfModule>