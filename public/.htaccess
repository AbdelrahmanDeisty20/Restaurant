DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. لو الملف موجود فعلياً (صورة أو ملف CSS/JS) شغله واطلع
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. القاعدة الجامعة: أي طلب يخص الأدمين، اللغة، الـ API، أو الـ Livewire
    # السطر ده هيخلي السيرفر يبعتهم للارافل غصب عنه
    RewriteCond %{REQUEST_URI} ^/(admin|api|livewire|filament|lang|language|set-locale) [NC]
    RewriteRule ^ index.php [L]

    # 3. أي حاجة تانية "أياً كانت" ابعتها للريأكت
    # تأكد إن ملف index.html موجود فعلاً في نفس الفولدر
    RewriteRule ^ index.html [L]
</IfModule>