DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # لو الملف موجود فعلياً (صورة، CSS، JS) شغله فوراً
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

   # استثناء مسارات الباك إند واللغة عشان ميروحوش للريأكت
    RewriteCond %{REQUEST_URI} ^/(admin|api|storage|login|logout|livewire|filament|language|lang) [NC]
RewriteRule ^ index.php [L]

    # أي حاجة تانية (زي /menu أو /about) ابعتها للريأكت
    RewriteRule ^ index.html [L]
</IfModule>